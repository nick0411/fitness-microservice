{
  "realm": "fitness-oauth2",
  "enabled": true,
  "clients": [
    {
      "clientId": "oauth2-pkce-client",
      "publicClient": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}